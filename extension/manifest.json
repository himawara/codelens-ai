{
  "manifest_version": 3,
  "name": "CodeLens AI",
  "version": "1.0.0",
  "description": "Socratic hints for LeetCode — powered by Gemini. Never gives you the answer.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*", "https://leetcode.com/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
